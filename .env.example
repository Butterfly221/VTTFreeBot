# VTTFreeBot Configuration
# Copy this file to .env and fill in your settings

# Mode: "telegram", "desktop", or "vk"
RUN_MODE=telegram

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# VK Configuration (for VK mode)
VK_TOKEN=
VK_GROUP_ID=0

# ASR Model Settings
# Size: "tiny", "base", "small"
ASR_MODEL_SIZE=base
# Compute type: "int8", "float16", "float32"
ASR_COMPUTE_TYPE=int8
# Device: "cpu", "cuda"
ASR_DEVICE=cpu

# Limits
MAX_FILE_SIZE_MB=25
MAX_AUDIO_DURATION_SECONDS=600
USER_RATE_LIMIT_PER_MINUTE=5

# Queue
QUEUE_TIMEOUT_SECONDS=600

# Temp directory (use /dev/shm for tmpfs on Linux)
TEMP_DIR=/dev/shm

# WAV output sample rate
WAV_SAMPLE_RATE=16000